# ───────────────────────────────────────────────────────────────
# Скопируй этот файл в .env и впиши свои значения.
#   cp .env.example .env
# Файл .env в git НЕ попадает (он в .gitignore).
# ───────────────────────────────────────────────────────────────

# === Telegram ===
# Токен бота от @BotFather.
# Для ОДНОВРЕМЕННОГО запуска двух ботов нужны ДВА разных токена
# (Telegram разрешает только одно подключение на токен).
TELEGRAM_TOKEN_LOCAL=         # токен для локального бота (Anki напрямую)
TELEGRAM_TOKEN_CLOUD=         # токен для облачного бота (.apkg файлы)
# Если запускаешь только один бот — можно задать общий TELEGRAM_TOKEN:
# TELEGRAM_TOKEN=

# === LLM (нужен хотя бы один ключ) ===
# Claude — лучшее качество для медицинских карточек. Ключ: console.anthropic.com
ANTHROPIC_API_KEY=
# Модель Claude. По умолчанию дёшево и качественно — claude-haiku-4-5.
# Для максимума качества: claude-opus-4-8 (дороже).
ANTHROPIC_MODEL=claude-haiku-4-5

# Gemini — бесплатный щедрый лимит. Ключ: aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Какой провайдер использовать по умолчанию: claude | gemini
# (в чате можно переключать командами /claude и /gemini)
LLM_PROVIDER=claude

# === Голосовые сообщения (опционально) ===
# Расшифровка речи через Groq Whisper (бесплатно). Ключ: console.groq.com/keys
# Без этого ключа голосовые просто игнорируются.
GROQ_API_KEY=

# === AnkiConnect (только для локального бота) ===
# Адрес аддона AnkiConnect. Менять не нужно, если Anki на том же компьютере.
ANKICONNECT_URL=http://localhost:8765

# === Мини-приложение (Telegram Mini App, только облачный бот) ===
# Публичный HTTPS-адрес, на котором облачный бот отдаёт мини-приложение.
# На Railway: Settings → Networking → Generate Domain, сюда впиши этот URL
# (например https://ankicloudbot-production.up.railway.app).
# Без него бот работает как раньше, но кнопка «Открыть мини-приложение» не появится.
WEBAPP_URL=
# Порт веб-сервера. Локально по умолчанию 8080; на Railway/Render задаётся
# автоматически переменной PORT — её менять не нужно.
# PORT=8080
# Файл базы данных мини-приложения (история, карточки, прогресс).
# На Railway подключи Volume и укажи путь на нём, иначе база сбрасывается
# при каждом деплое, например: ANKI_DB_PATH=/data/ankicloud.db
ANKI_DB_PATH=ankicloud.db
